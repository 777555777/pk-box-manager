{
	"name": "pk-box-manager",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "npm run pre-deploy && vite preview --host",
		"fast-preview": "vite preview --host",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run tests/pokemon-stats-coverage.test.ts",
		"test:docs": "vitest run tests/pokemon-stats-documentation.test.ts",
		"sprites": "npm run generate-ball-sprites && npm run generate-box-wallpaper-sprites && npm run generate-box-title-sprites && npm run generate-pokemon-sprites && npm run generate-form-sprites && npm run generate-shiny-pokemon-sprites && npm run generate-shiny-form-sprites",
		"generate-mark-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/marks --output-dir=static/spritesheets/util --ts-dir=src/lib/models --name=marks --tile-width=48 --column-amount=8 --max-images=150",
		"generate-ribbon-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/ribbons --output-dir=static/spritesheets/util --ts-dir=src/lib/models --name=ribbons --tile-width=40 --column-amount=8 --max-images=150",
		"generate-ball-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/balls --output-dir=static/spritesheets/util --ts-dir=src/lib/models --name=balls --tile-width=30 --column-amount=8 --max-images=50",
		"generate-box-wallpaper-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/boxes/wallpapers --output-dir=static/spritesheets/util --ts-dir=src/lib/models --name=wallpapers --tile-width=567 --tile-height=427 --column-amount=5 --max-images=50",
		"generate-box-title-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/boxes/titles --output-dir=static/spritesheets/util --ts-dir=src/lib/models --name=titles --tile-width=406 --tile-height=81 --column-amount=4 --max-images=50",
		"generate-pokemon-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/pokemon/normal --output-dir=static/spritesheets/pokemon --name=pokemon --ts-dir=src/lib/models --tile-width=96 --column-amount=15 --max-images=300",
		"generate-form-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/pokemon/forms --output-dir=static/spritesheets/pokemon --name=forms --ts-dir=src/lib/models --tile-width=96 --column-amount=15 --max-images=300",
		"generate-shiny-pokemon-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/pokemon/shiny-normal --output-dir=static/spritesheets/shiny-pokemon --name=pokemon --tile-width=96 --column-amount=15 --max-images=300 --no-ts",
		"generate-shiny-form-sprites": "node project-data/src/generate-sprites.ts --input-dir=project-data/images/pokemon/shiny-forms --output-dir=static/spritesheets/shiny-pokemon --name=forms --tile-width=96 --column-amount=15 --max-images=300 --no-ts",
		"webp": "cd ./static && ./convertWebP.sh",
		"pre-deploy": "npm run build && npm run sprites && npm run webp",
		"deploy": "./deploy.sh"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.2",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.1",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24.6.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.50.0",
		"svelte-check": "^4.3.6",
		"svelte-render-scan": "^1.1.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	}
}
